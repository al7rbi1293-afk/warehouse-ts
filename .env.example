# Database
# `DATABASE_URL` is used by Prisma runtime queries in `schema.prisma`.
# For Vercel/serverless production, use the Supabase pooler URL.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# `DIRECT_URL` is used by Prisma direct operations such as migrate/introspection.
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Canonical production URL (used for metadata and sharing links)
NEXT_PUBLIC_SITE_URL="https://your-domain.example"
