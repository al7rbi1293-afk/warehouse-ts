# Database - keep `DATABASE_URL` for local tools and set `SUPABASE_POOLER_URL`
# on Vercel production to use Supabase's transaction pooler with Prisma.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
SUPABASE_POOLER_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Canonical production URL (used for metadata and sharing links)
NEXT_PUBLIC_SITE_URL="https://your-domain.example"
