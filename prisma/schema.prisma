generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id(map: "User_pkey") @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String
  region    String?  // Legacy single region (kept for backwards compatibility)
  regions   String?  @map("regions") // Multi-zone: comma-separated list of assigned zones
  shiftId       Int?     @map("shift_id")
  shift         Shift?   @relation(fields: [shiftId], references: [id])
  attendanceShiftId Int? @map("attendance_shift_id") // Attendance shift if different from primary
  allowedShifts String?  @map("allowed_shifts")
  empId         String?  @map("emp_id")
  createdAt     DateTime @default(now()) @map("created_at")

  attendance StaffAttendance[] @relation("UserAttendance")
  covering   StaffAttendance[] @relation("CoveringUser")
  reportAnswers ReportAnswer[]
  dailyReportSubmissions DailyReportSubmission[]
  dischargeReportEntries DischargeReportEntry[]
  reportReviews ReportReview[]

  @@map("users")
}

model StaffAttendance {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  date      DateTime @db.Date
  status    String?  // Present, Absent, Vacation, Day Off, Sick Leave
  coveredBy Int?     @map("covered_by") // User ID of the covering supervisor
  substituteActive Boolean @default(false) @map("substitute_active") // Is substitute currently active?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation("UserAttendance", fields: [userId], references: [id])
  coverUser User?    @relation("CoveringUser", fields: [coveredBy], references: [id])

  @@unique([userId, date])
  @@map("staff_attendance")
}

model Shift {
  id        Int      @id @default(autoincrement())
  name      String
  startTime String?  @map("start_time")
  endTime   String?  @map("end_time")
  workers   Worker[]
  users     User[]

  @@map("shifts")
}

model Worker {
  id        Int       @id @default(autoincrement())
  name      String
  role      String?
  region    String?
  status    String?   @default("Active")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  shiftId   Int?      @map("shift_id")
  empId     String?   @map("emp_id")
  shift     Shift?    @relation(fields: [shiftId], references: [id])
  attendance Attendance[]

  @@map("workers")
}

model Attendance {
  id         Int       @id @default(autoincrement())
  workerId   Int       @map("worker_id")
  date       DateTime  @db.Date
  status     String?
  shiftId    Int?      @map("shift_id")
  returnDate DateTime? @map("return_date") @db.Date
  notes      String?
  supervisor String?
  createdAt  DateTime  @default(now()) @map("created_at")
  worker     Worker    @relation(fields: [workerId], references: [id])

  @@index([date])
  @@index([workerId])
  @@map("attendance")
}

model Inventory {
  id          Int       @id(map: "Inventory_pkey") @default(autoincrement())
  nameEn      String    @map("name_en")
  nameAr      String?   @map("name_ar")
  itemCode    String?   @map("item_code")
  category    String
  location    String
  qty         Int       @default(0)
  minThreshold Int      @default(10) @map("min_threshold")
  unit        String
  status      String    @default("Available")
  lastUpdated DateTime? @map("last_updated") @db.Timestamp(6)

  @@index([itemCode])
  @@map("inventory")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model LocalInventory {
  region      String
  itemName    String    @map("item_name")
  qty         Int?
  lastUpdated DateTime? @map("last_updated") @db.Timestamp(6)
  updatedBy   String?   @map("updated_by")

  @@id([region, itemName])
  @@map("local_inventory")
}

model Request {
  reqId          Int       @id @default(autoincrement()) @map("req_id")
  supervisorName String?   @map("supervisor_name")
  region         String?
  itemName       String?   @map("item_name")
  category       String?
  qty            Int?
  unit           String?
  status         String?
  requestDate    DateTime? @default(now()) @map("request_date") @db.Timestamp(6)
  notes          String?
  issuedBy       String?   @map("issued_by")
  issuedAt       DateTime? @map("issued_at")
  shiftId        Int?      @map("shift_id")
  shiftName      String?   @map("shift_name")
  reviewedBy     String?   @map("reviewed_by")
  reviewedAt     DateTime? @map("reviewed_at")
  approvedBy     String?   @map("approved_by")
  approvedAt     DateTime? @map("approved_at")
  receivedAt     DateTime? @map("received_at")

  @@index([status])
  @@index([region])
  @@index([supervisorName])
  @@index([requestDate])
  @@map("requests")
}

model StockLog {
  id           Int       @id @default(autoincrement())
  logDate      DateTime? @default(now()) @map("log_date") @db.Timestamp(6)
  itemName     String?   @map("item_name")
  changeAmount Int?      @map("change_amount")
  location     String?
  actionBy     String?   @map("action_by")
  actionType   String?   @map("action_type")
  unit         String?
  newQty       Int?      @map("new_qty")
  userName     String?   @map("user_name")

  @@index([logDate])
  @@map("stock_logs")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  userName  String   @map("user_name")
  action    String
  details   String?
  module    String?

  @@map("audit_logs")
}

model WarehouseBulkOperation {
  id              Int                        @id @default(autoincrement())
  operationNo     String                     @unique @map("operation_no")
  operationType   String                     @map("operation_type")
  status          String                     @default("Completed")
  createdBy       String                     @map("created_by")
  createdByUserId Int?                       @map("created_by_user_id")
  notes           String?
  metadata        Json?
  submittedAt     DateTime?                  @map("submitted_at") @db.Timestamp(6)
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime                   @updatedAt @map("updated_at") @db.Timestamp(6)
  lines           WarehouseBulkOperationLine[]

  @@index([operationType])
  @@index([status])
  @@index([createdAt])
  @@map("warehouse_bulk_operations")
}

model WarehouseBulkOperationLine {
  id                  Int                    @id @default(autoincrement())
  bulkOperationId     Int                    @map("bulk_operation_id")
  lineNo              Int                    @map("line_no")
  entityType          String?                @map("entity_type")
  entityId            Int?                   @map("entity_id")
  status              String                 @default("Pending")
  itemId              Int?                   @map("item_id")
  itemName            String                 @map("item_name")
  itemCode            String?                @map("item_code")
  category            String?
  unit                String?
  quantity            Int
  approvedQty         Int?                   @map("approved_qty")
  fulfilledQty        Int?                   @map("fulfilled_qty")
  availableQtySnapshot Int?                  @map("available_qty_snapshot")
  fromWarehouse       String?                @map("from_warehouse")
  toWarehouse         String?                @map("to_warehouse")
  region              String?
  projectName         String?                @map("project_name")
  expectedReturnDate  DateTime?              @map("expected_return_date") @db.Timestamp(6)
  notes               String?
  metadata            Json?
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime               @updatedAt @map("updated_at") @db.Timestamp(6)
  bulkOperation       WarehouseBulkOperation @relation(fields: [bulkOperationId], references: [id], onDelete: Cascade)

  @@unique([bulkOperationId, lineNo])
  @@index([entityType, entityId])
  @@index([status])
  @@index([itemName])
  @@index([fromWarehouse, toWarehouse])
  @@map("warehouse_bulk_operation_lines")
}

model Project {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(255)
  type      String    @db.VarChar(50)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  status    String    @default("Active")

  @@map("projects")
}

model Warehouse {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  type      String?   @map("type")
  location  String?
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("warehouses")
}

model Region {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime? @default(now()) @map("created_at")

  @@map("regions")
}

model loan {
  id              Int    @id(map: "Loan_pkey") @default(autoincrement())
  itemId          Int
  itemName        String
  project         String
  quantity        Int
  originalQuantity Int?  @map("original_quantity")
  returnedQuantity Int   @default(0) @map("returned_quantity")
  type            String
  sourceWarehouse String? @map("source_warehouse")
  date            String
  status          String @default("Active")
  expectedReturnDate DateTime? @map("expected_return_date") @db.Timestamp(6)
  returnDate      DateTime? @map("return_date") @db.Timestamp(6)
  reference       String?
  notes           String?
}

model ReportQuestion {
  id        Int      @id @default(autoincrement())
  reportType String  @map("report_type")
  question  String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  answers   ReportAnswer[]

  @@index([reportType, sortOrder])
  @@map("report_questions")
}

model ReportAnswer {
  id             Int            @id @default(autoincrement())
  questionId     Int            @map("question_id")
  reportDate     DateTime       @map("report_date") @db.Date
  answer         String
  supervisorId   Int            @map("supervisor_id")
  supervisorName String         @map("supervisor_name")
  area           String         @default("")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  question       ReportQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  supervisor     User           @relation(fields: [supervisorId], references: [id], onDelete: Cascade)

  @@unique([questionId, reportDate, supervisorId, area])
  @@index([reportDate])
  @@index([supervisorId])
  @@index([reportDate, supervisorId, area])
  @@map("report_answers")
}

model DailyReportSubmission {
  id               Int      @id @default(autoincrement())
  reportDate       DateTime @map("report_date") @db.Date
  supervisorId     Int      @map("supervisor_id")
  supervisorName   String   @map("supervisor_name")
  region           String
  roundNumber      String   @map("round_number")
  checklistAnswers Json     @map("checklist_answers")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  supervisor       User     @relation(fields: [supervisorId], references: [id], onDelete: Cascade)

  @@unique([reportDate, supervisorId, roundNumber])
  @@index([reportDate])
  @@index([supervisorId])
  @@map("daily_report_submissions")
}

model DischargeReportEntry {
  id             Int      @id @default(autoincrement())
  reportDate     DateTime @map("report_date") @db.Date
  dischargeDate  DateTime @map("discharge_date") @db.Date
  supervisorId   Int      @map("supervisor_id")
  supervisorName String   @map("supervisor_name")
  area           String
  roomNumber     String   @map("room_number")
  roomType       String   @map("room_type")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  supervisor     User     @relation(fields: [supervisorId], references: [id], onDelete: Cascade)

  @@index([reportDate])
  @@index([dischargeDate])
  @@index([supervisorId])
  @@index([reportDate, supervisorId])
  @@map("discharge_report_entries")
}

model ReportReview {
  id              Int      @id @default(autoincrement())
  reportType      String   @map("report_type")
  reportDate      DateTime @map("report_date") @db.Date
  supervisorId    Int      @map("supervisor_id")
  supervisorName  String   @map("supervisor_name")
  area            String   @default("")
  roundNumber     String   @default("") @map("round_number")
  status          String   @default("Submitted")
  correctionCount Int      @default(0) @map("correction_count")
  resubmissionCount Int    @default(0) @map("resubmission_count")
  firstSubmittedAt DateTime @default(now()) @map("first_submitted_at") @db.Timestamp(6)
  lastSubmittedAt DateTime  @default(now()) @map("last_submitted_at") @db.Timestamp(6)
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamp(6)
  reviewedBy      String?   @map("reviewed_by")
  reviewNotes     String?   @map("review_notes")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  supervisor      User      @relation(fields: [supervisorId], references: [id], onDelete: Cascade)

  @@unique([reportType, reportDate, supervisorId, area, roundNumber])
  @@index([reportType, status])
  @@index([supervisorId, reportDate])
  @@index([reportType, reportDate])
  @@map("report_reviews")
}

model DailyReportTemplate {
  id        Int      @id @default(autoincrement())
  template  Json
  createdBy String?  @map("created_by")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("daily_report_templates")
}
